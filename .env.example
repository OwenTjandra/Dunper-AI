# Copy this file to .env and fill in your real values.
# Get an Anthropic API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
PORT=3000

# Admin login — used to seed the first admin user on first run.
# After the user is created in data.db, changing these has no effect
# (you'd need to delete data.db or add a password-reset flow).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Google integration — OPTIONAL. Bookings sync to Google Calendar and a Google Sheet
# (with auto-created "Bookings" and "Customers" tabs) when these are set.
# 1) Path to your service-account JSON (relative to project root or absolute):
GOOGLE_CREDENTIALS_PATH=./ai-frontdesk-495621-c1c679e97a5c.json
# 2) Calendar ID — use "primary" for the service-account's own calendar, or paste
#    your business calendar's ID (Settings → Integrate calendar → Calendar ID).
#    The calendar must be shared with the service-account email (Editor access).
GOOGLE_CALENDAR_ID=primary
# 3) Spreadsheet ID — the long ID from the Google Sheet URL (between /d/ and /edit).
#    The sheet must be shared with the service-account email (Editor access).
GOOGLE_SHEET_ID=
