# Copy this file to .env and fill in your real values.
# Get an Anthropic API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
PORT=3000

# Admin login — used to seed the first business_owner user on first run.
# After the user is created in data.db, changing these has no effect
# (you'd need to delete data.db or add a password-reset flow).
# Business owners get the /admin.html dashboard.
#
# If ADMIN_EMAIL is set, 2FA is enabled — every login mails a 6-digit
# code to that address that the user has to enter to finish signing in.
# If blank, the account signs in with just username + password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
ADMIN_EMAIL=

# Founder logins — seeds founder users with access to /operator.html
# (the founder god-view dashboard with sales CRM). Strictly separate from
# business_owner; founders cannot access /admin.html, business_owners
# cannot access /operator.html.
# Format: comma-separated entries. Each entry is either
#   username:password           (no 2FA — legacy)
# or
#   username:password:email     (2FA on — code mailed on every sign-in)
# Idempotent — usernames already in data.db are skipped (passwords
# are NEVER overwritten).
# Example with 2FA:
#   FOUNDERS=alice:alicepw:alice@gmail.com,bob:bobpw:bob@gmail.com
FOUNDERS=

# Pending-login signing secret — HMAC for the short cookie that links
# step 1 (creds) to step 2 (code). If unset, falls back to
# ANTHROPIC_API_KEY. Set explicitly in production.
PENDING_LOGIN_SECRET=

# Google integration — OPTIONAL. The business owner connects their own Google
# account from the dashboard ("Connect Google" button). The deploy only needs
# OAuth client credentials.
#
# Set up at https://console.cloud.google.com → APIs & Services → Credentials:
#   1. Enable Google Calendar API, Google Sheets API, and Google Drive API.
#   2. OAuth consent screen → External → add scopes for calendar, spreadsheets,
#      drive.file → add yourself as a test user.
#   3. Create OAuth client ID (Web application). Add this redirect URI:
#        http://localhost:3000/api/integrations/google/callback
#      (Add your production URL too when deploying.)
#   4. Copy the Client ID and Client secret here:
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# WhatsApp Cloud API — OPTIONAL. When set, customers messaging your WhatsApp
# Business number get auto-replies from the AI. See docs/whatsapp-setup.md
# for the full Meta Business Manager + Cloudflare Tunnel walkthrough.
# 1) Phone Number ID from Meta dashboard (NOT the phone number itself):
WHATSAPP_PHONE_NUMBER_ID=
# 2) Access token (start with the temporary 24h one from Meta, replace later
#    with a permanent System User token):
WHATSAPP_ACCESS_TOKEN=
# 3) Verify token — any string YOU choose. You'll paste this same string in
#    Meta's webhook config so Meta proves it's talking to your server:
WHATSAPP_VERIFY_TOKEN=
# 4) App Secret (optional, recommended) — from Meta App → Settings → Basic.
#    When set, server validates webhook payloads using HMAC SHA-256.
WHATSAPP_APP_SECRET=

# Email (booking confirmations) — OPTIONAL. When SMTP_* are set, customers
# receive an email confirmation after booking. When unset, the email is
# logged to email_outbox table with status='skipped_no_smtp' so the owner
# can see what would have gone out.
#
# Easiest: Gmail with an App Password.
#   1. Enable 2-Step Verification on your Google account
#   2. https://myaccount.google.com/apppasswords → create one for "Mail"
#   3. Use that 16-char password below as SMTP_PASS (NOT your normal pw)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=
