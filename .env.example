# Copy this file to .env and fill in your real values.
# Get an Anthropic API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
PORT=3000

# Admin login — used to seed the first admin user on first run.
# After the user is created in data.db, changing these has no effect
# (you'd need to delete data.db or add a password-reset flow).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Google integration — OPTIONAL. The business owner connects their own Google
# account from the dashboard ("Connect Google" button). The deploy only needs
# OAuth client credentials.
#
# Set up at https://console.cloud.google.com → APIs & Services → Credentials:
#   1. Enable Google Calendar API, Google Sheets API, and Google Drive API.
#   2. OAuth consent screen → External → add scopes for calendar, spreadsheets,
#      drive.file → add yourself as a test user.
#   3. Create OAuth client ID (Web application). Add this redirect URI:
#        http://localhost:3000/api/integrations/google/callback
#      (Add your production URL too when deploying.)
#   4. Copy the Client ID and Client secret here:
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
